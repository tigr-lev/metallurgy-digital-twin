          "padding": "0px",
          "settings": {
            "cardHtml": "<div style=\"\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    gap: 20px;\r\n    padding: 25px;\r\n    background: linear-gradient(135deg, #1e272e 0%, #0f1418 100%);\r\n    border-radius: 12px;\r\n    font-family: 'Segoe UI', sans-serif;\r\n    color: #ecf0f1;\r\n    box-shadow: 0 12px 40px rgba(0,0,0,0.6);\r\n\">\r\n\r\n    <div style=\"\r\n        width: 100%;\r\n        display: flex;\r\n        justify-content: space-between;\r\n        align-items: center;\r\n        border-bottom: 1px solid rgba(255,255,255,0.1);\r\n        padding-bottom: 10px;\r\n    \">\r\n        <div style=\"font-size: 14px; font-weight: bold; color: #ecf0f1;\">\r\n            Рекомендательная система температуры плавки\r\n        </div>\r\n        <div style=\"\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 5px;\r\n            color: ${status === 'unreachable' ? '#e74c3c' : '#27ae60'};\r\n            font-weight: bold;\r\n            font-size: 12px;\r\n            text-transform: uppercase;\r\n        \">\r\n            <span style=\"font-size: 14px;\">●</span> ${status}\r\n        </div>\r\n    </div>\r\n\r\n    <div style=\"display: flex; gap: 40px; align-items: center; width: 100%; justify-content: center;\">\r\n\r\n        <svg width=\"180\" height=\"260\" viewBox=\"0 0 200 280\">\r\n            <defs>\r\n                <radialGradient id=\"moltenGlow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\r\n                    <stop offset=\"0%\" stop-color=\"\r\n                    ${decision === 'overheat' ? '#ff7675' : \r\n                      decision === 'underheat' ? '#74b9ff' : \r\n                      decision === 'inefficient' ? '#ffeaa7' : \r\n                      '#55efc4'}\"/>\r\n                    <stop offset=\"100%\" stop-color=\"#c0392b\"/>\r\n                </radialGradient>\r\n                \r\n                <clipPath id=\"ladleClip\">\r\n                    <path d=\"M 50 55 L 150 55 L 132 230 L 68 230 Z\" />\r\n                </clipPath>\r\n            </defs>\r\n\r\n            <ellipse cx=\"100\" cy=\"255\" rx=\"55\" ry=\"8\" fill=\"#000\" opacity=\"0.4\"/>\r\n            <path d=\"M 40 40 L 160 40 L 142 240 L 58 240 Z\" fill=\"#2c3e50\" />\r\n\r\n            <rect x=\"40\" y=\"${160 - (predicted - 1580)*1.5}\" width=\"120\" height=\"200\"\r\n                  fill=\"url(#moltenGlow)\" clip-path=\"url(#ladleClip)\" opacity=\"0.9\" />\r\n\r\n            <g opacity=\"${action === 'increase_energy' ? '1' : '0.2'}\">\r\n                <rect x=\"85\" y=\"5\" width=\"8\" height=\"100\" fill=\"#1e1e1e\" rx=\"2\" />\r\n                <rect x=\"107\" y=\"5\" width=\"8\" height=\"100\" fill=\"#1e1e1e\" rx=\"2\" />\r\n                <circle cx=\"100\" cy=\"115\" r=\"10\" fill=\"#fff\" opacity=\"${action === 'increase_energy' ? '0.4' : '0'}\" />\r\n            </g>\r\n        </svg>\r\n\r\n        <div style=\"display: flex; flex-direction: column; gap: 15px; width: 300px;\">\r\n\r\n            <div style=\"\r\n                padding: 12px;\r\n                border-radius: 8px;\r\n                font-weight: bold;\r\n                text-align: center;\r\n                background:\r\n                ${decision === 'overheat' ? 'rgba(255, 107, 107, 0.12)' :\r\n                  decision === 'underheat' ? 'rgba(77, 171, 247, 0.12)' :\r\n                  decision === 'inefficient' ? 'rgba(241, 196, 15, 0.12)' :\r\n                  'rgba(46, 204, 113, 0.12)'};\r\n                color:\r\n                ${decision === 'overheat' ? '#ff6b6b' :\r\n                  decision === 'underheat' ? '#4dabf7' :\r\n                  decision === 'inefficient' ? '#f1c40f' :\r\n                  '#2ecc71'};\r\n            \">\r\n                ${decision === 'overheat' ? '⚠ ТЕМПЕРАТУРА ВЫШЕ НОРМЫ' :\r\n                  decision === 'underheat' ? '⬆ ТРЕБУЕТСЯ НАГРЕВ' :\r\n                  decision === 'inefficient' ? '💡 ИЗБЫТОЧНАЯ ЭНЕРГИЯ' :\r\n                  '✔ РЕЖИМ СТАБИЛЕН'}\r\n            </div>\r\n\r\n            <div style=\"font-size: 14px; font-weight: bold; display: flex; align-items: center; gap: 10px;\">\r\n                <span style=\"font-size: 18px;\">\r\n                    ${action === 'reduce_energy' ? '⬇' : action === 'increase_energy' ? '⬆' : '➡'}\r\n                </span>\r\n                ${action === 'reduce_energy' ? 'СНИЗИТЬ МОЩНОСТЬ' :\r\n                  action === 'increase_energy' ? 'ВКЛЮЧИТЬ ЭЛЕКТРОДЫ' :\r\n                  'ПОДДЕРЖИВАТЬ ТЕКУЩИЙ ХОД'}\r\n            </div>\r\n\r\n            <div style=\"\r\n                display: flex;\r\n                flex-direction: column;\r\n                gap: 10px;\r\n                padding: 15px;\r\n                background: rgba(255,255,255,0.03);\r\n                border-radius: 8px;\r\n            \">\r\n                <div style=\"display: flex; justify-content: space-between; font-size: 14px;\">\r\n                    <span style=\"color:#95a5a6;\">Прогноз:</span>\r\n                    <span style=\"font-weight: bold;\">${predicted} °C</span>\r\n                </div>\r\n                <div style=\"display: flex; justify-content: space-between; font-size: 14px;\">\r\n                    <span style=\"color:#95a5a6;\">Цель:</span>\r\n                    <span style=\"font-weight: bold;\">${target} °C</span>\r\n                </div>\r\n                <div style=\"display: flex; justify-content: space-between; margin-top: 5px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.1);\">\r\n                    <span style=\"color:#95a5a6;\">Коррекция (ΔE):</span>\r\n                    <span style=\"font-weight: bold; color:${delta_energy < 0 ? '#4dabf7' : '#ff6b6b'};\">\r\n                        ${delta_energy > 0 ? '+' : ''}${delta_energy} MJ\r\n                    </span>\r\n                </div>\r\n                <div style=\"display: flex; justify-content: space-between; align-items: center;\">\r\n                    <span style=\"color:#95a5a6;\">Критичность:</span>\r\n                    <div style=\"display: flex; align-items: center; gap: 8px;\">\r\n                        <div style=\"width: 8px; height: 8px; border-radius: 50%; background: ${severity === 'critical' ? '#ff3b3b' : severity === 'warning' ? '#f39c12' : '#27ae60'};\"></div>\r\n                        <span style=\"font-weight: bold; text-transform: uppercase; font-size: 11px;\">${severity}</span>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div style=\"\r\n                font-size: 12px;\r\n                color:#bdc3c7;\r\n                padding: 10px;\r\n                border-left: 3px solid #7f8c8d;\r\n                background: rgba(0,0,0,0.2);\r\n                font-style: italic;\r\n                border-radius: 0 4px 4px 0;\r\n            \">\r\n                \"${message}\"\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>",
            "cardCss": ".card {\n   width: 100%;\n   height: 100%;\n   border: 2px solid #ccc;\n   box-sizing: border-box;\n}\n\n.card .content {\n   padding: 20px;\n   display: flex;\n   flex-direction: row;\n   align-items: center;\n   justify-content: space-around;\n   height: 100%;\n   box-sizing: border-box;\n}\n\n.card .content .column {\n   display: flex;\n   flex-direction: column;    \n   justify-content: space-around;\n   height: 100%;\n}\n\n.card h1 {\n    text-transform: uppercase;\n    color: #999;\n    font-size: 20px;\n    font-weight: bold;\n    margin: 0;\n    padding-bottom: 10px;\n    line-height: 32px;\n}\n\n.card .value {\n    font-size: 38px;\n    font-weight: 200;\n}\n\n.card .description {\n    font-size: 20px;\n    color: #999;\n}\n"
