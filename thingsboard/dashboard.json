          "settings": {
            "useMarkdownTextFunction": false,
            "markdownTextPattern": "<div style=\"font-family: 'Segoe UI', sans-serif; padding: 7px; color: #d1d4db;\">\r\n\r\n  <h2 style=\"text-align: center; color: #4facfe; margin-bottom: 4px;\">📊 DECISION SUPPORT REPORT</h2>\r\n  <p style=\"text-align: center; font-size: 0.9em; color: #888; margin-bottom: 6px;\">Live session analytics (AI + Physics model)</p>\r\n\r\n  <hr style=\"border: 0.5px solid #444; margin: 6px 0;\">\r\n\r\n  <!-- TOTAL -->\r\n  <table style=\"width: 100%; margin-top: 10px;\">\r\n    <tr>\r\n      <td style=\"font-size: 1.05em;\">⚙️ Всего событий:</td>\r\n      <td style=\"text-align: right; font-weight: bold; font-size: 1.2em; color: #fff;\">${stat_total}</td>\r\n    </tr>\r\n  </table>\r\n\r\n  <!-- STATUS -->\r\n  <div style=\"display: flex; justify-content: space-between; margin-top: 8px; background: #2c2f33; padding: 8px; border-radius: 5px;\">\r\n    <div style=\"text-align: center;\">\r\n      <div style=\"color: #43b581; font-size: 1.2em; font-weight: bold;\">${stat_stable}</div>\r\n      <div style=\"font-size: 0.75em; color: #888;\">Stable</div>\r\n    </div>\r\n    <div style=\"text-align: center;\">\r\n      <div style=\"color: #00aaff; font-size: 1.2em; font-weight: bold;\">${stat_optimal}</div>\r\n      <div style=\"font-size: 0.75em; color: #888;\">Optimal</div>\r\n    </div>\r\n    <div style=\"text-align: center;\">\r\n      <div style=\"color: #faa61a; font-size: 1.2em; font-weight: bold;\">${stat_unreachable}</div>\r\n      <div style=\"font-size: 0.75em; color: #888;\">Unreachable</div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- DECISION -->\r\n  <h3 style=\"margin-top: 16px; font-size: 1em; color: #ffcc00;\">🌡️ ТЕМПЕРАТУРНЫЙ РЕЖИМ</h3>\r\n  <ul style=\"list-style: none; padding: 0; font-size: 0.95em; line-height: 1.5;\">\r\n    <li>🔴 Перегрев: <strong style=\"color: #ff4d4d;\">${stat_overheat}</strong></li>\r\n    <li>🔵 Недогрев: <strong style=\"color: #4facfe;\">${stat_underheat}</strong></li>\r\n    <li>💡 Неэффективность: <strong style=\"color: #f1c40f;\">${stat_inefficient}</strong></li>\r\n  </ul>\r\n\r\n  <!-- ENERGY -->\r\n  <h3 style=\"margin-top: 16px; font-size: 1em; color: #00ffcc;\">⚡ ЭНЕРГИЯ</h3>\r\n  <div style=\"background: linear-gradient(90deg, #1e3c72 0%, #2a5298 100%); padding: 10px; border-radius: 5px; border-left: 5px solid #00ffcc;\">\r\n    <div style=\"font-size: 0.85em; color: #bbb;\">Потенциал экономии:</div>\r\n    <div style=\"font-size: 1.3em; font-weight: bold; color: #fff;\">${stat_energy_saved} MJ</div>\r\n    <div style=\"font-size: 0.8em; margin-top: 4px; color: #ddd;\">Доп. нагрев: ${stat_energy_added} MJ</div>\r\n  </div>\r\n\r\n  <!-- SEVERITY -->\r\n  <h3 style=\"margin-top: 16px; font-size: 1em; color: #ff4d4d;\">🚨 РИСКИ</h3>\r\n  <div style=\"display: flex; gap: 8px;\">\r\n    <div style=\"flex: 1; background: #3c1e1e; padding: 7px; border-radius: 3px; text-align: center;\">\r\n      <div style=\"font-size: 0.75em; color: #ff4d4d;\">CRITICAL</div>\r\n      <div style=\"font-size: 1.2em; font-weight: bold;\">${stat_critical}</div>\r\n    </div>\r\n    <div style=\"flex: 1; background: #3c351e; padding: 7px; border-radius: 3px; text-align: center;\">\r\n      <div style=\"font-size: 0.75em; color: #faa61a;\">WARNING</div>\r\n      <div style=\"font-size: 1.2em; font-weight: bold;\">${stat_warning}</div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- FOOTER -->\r\n  <p style=\"font-size: 0.7em; color: #555; margin-top: 12px; text-align: center;\">\r\n    Data resets on API restart\r\n  </p>\r\n\r\n</div>",
